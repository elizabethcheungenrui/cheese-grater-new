{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/500/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/about/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/archive/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/article/([^/]+?)/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/author/([^/]+?)/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/awards/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/contact/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/get-involved/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/life-members/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/past-editors/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/past-issues/([^/]+?)/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/past-issues/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/resources/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/robots\\.txt/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/search/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/tips/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/welfare/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/([^/]+?)/([^/]+?)/([^/]+?)/([^/]+?)/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}